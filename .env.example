# Copy this file to .env — works immediately with no setup (local SQLite file).
DATABASE_URL="file:./dev.db"

# To deploy to Vercel (or any host without a persistent filesystem), switch
# this to a Postgres connection string instead (e.g. from neon.tech or
# Vercel's Storage tab), change the datasource provider in
# prisma/schema.prisma to "postgresql", and swap the adapter in lib/db.ts
# from PrismaBetterSqlite3 to PrismaPg (@prisma/adapter-pg).
